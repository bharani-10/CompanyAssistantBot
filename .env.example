# Environment Configuration

# Groq API (Fast & Free!)
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq
TEMPERATURE=0.7

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000

# Document Configuration
PDF_DIRECTORY=.

# Chroma Vector Store
CHROMA_PERSIST_DIRECTORY=./chroma_db
